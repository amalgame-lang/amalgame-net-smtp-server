// Test suite for amalgame-net-smtp-server — the SmtpSession state
// machine, driven with strings against a real local MailStore +
// Credentials (no socket, no TLS). Base64 AUTH tokens are precomputed
// constants so the test needs no encoder.
//
// Style note: pull each method result into a typed local before calling
// another method on it (--external mode lowering).

namespace Tests

import Amalgame.Collections
import Amalgame.IO.Filesystem
import Amalgame.Database.SQLite
import Amalgame.Tls
import Amalgame.Net.Mail
import Amalgame.Net.SmtpServer

// Records what the injected relay closure was asked to forward (the closure
// captures an instance and mutates it, so the test can assert on it).
public class RelayRec {
    public Count:    int
    public LastFrom: string
    public LastTo:   string
    public Ok:       bool
    public RelayRec() { this.Count = 0; this.LastFrom = ""; this.LastTo = ""; this.Ok = true }
}

public class Program {
    public static void Main(string[] args) {
        let root: string = "/tmp/amalgame-smtp-test"
        Filesystem.Remove(root)                        // clean slate
        let store: MailStore = MailStore.Open(root)

        let s: SmtpSession = new SmtpSession(store, "mail.test")
        s.AddPassword("alice", "s3cret")

        // ── 1. greeting ──────────────────────────────────
        let greet: string = s.Greeting()
        if (String_Contains(greet, "220") && String_Contains(greet, "mail.test")) {
            Console.WriteLine("[PASS] greeting")
        } else { Console.WriteLine("[FAIL] greeting: " + greet) }

        // ── 2. EHLO advertises STARTTLS (pre-TLS), not AUTH ──
        let ehlo1: string = s.Feed("EHLO client.example")
        if (String_Contains(ehlo1, "250") && String_Contains(ehlo1, "STARTTLS")
            && !String_Contains(ehlo1, "AUTH")) {
            Console.WriteLine("[PASS] ehlo pre-tls caps")
        } else { Console.WriteLine("[FAIL] ehlo pre-tls caps: " + ehlo1) }

        // ── 3. AUTH refused before TLS ───────────────────
        let authNoTls: string = s.Feed("AUTH LOGIN")
        if (String_Contains(authNoTls, "538")) { Console.WriteLine("[PASS] auth refused pre-tls") }
        else { Console.WriteLine("[FAIL] auth refused pre-tls: " + authNoTls) }

        // ── 4. STARTTLS signal ───────────────────────────
        let st: string = s.Feed("STARTTLS")
        let wants: bool = s.WantsTlsUpgrade()
        if (String_Contains(st, "220") && wants) { Console.WriteLine("[PASS] starttls signal") }
        else { Console.WriteLine("[FAIL] starttls signal: " + st) }
        s.SetTlsActive(true)

        // ── 5. EHLO after TLS advertises AUTH, not STARTTLS ──
        let ehlo2: string = s.Feed("EHLO client.example")
        if (String_Contains(ehlo2, "AUTH") && !String_Contains(ehlo2, "STARTTLS")) {
            Console.WriteLine("[PASS] ehlo post-tls caps")
        } else { Console.WriteLine("[FAIL] ehlo post-tls caps: " + ehlo2) }

        // ── 6. AUTH LOGIN success (alice / s3cret) ───────
        let a1: string = s.Feed("AUTH LOGIN")            // → 334 Username:
        let a2: string = s.Feed("YWxpY2U=")              // base64("alice") → 334 Password:
        let a3: string = s.Feed("czNjcmV0")              // base64("s3cret") → 235
        let authed: bool = s.Authed
        if (String_Contains(a1, "334") && String_Contains(a2, "334")
            && String_Contains(a3, "235") && authed) {
            Console.WriteLine("[PASS] auth login success")
        } else { Console.WriteLine("[FAIL] auth login: " + a1 + "|" + a2 + "|" + a3) }

        // ── 7. MAIL/RCPT/DATA delivery ───────────────────
        let e3: string = s.Feed("EHLO client.example")   // re-EHLO post-auth
        let m: string = s.Feed("MAIL FROM:<sender@example.com>")
        let r: string = s.Feed("RCPT TO:<alice@mail.test>")
        let d: string = s.Feed("DATA")
        let b1: string = s.Feed("Subject: Hi")
        let b2: string = s.Feed("")
        let b3: string = s.Feed("Hello body")
        let b4: string = s.Feed("..dotted line")         // dot-stuffed
        let fin: string = s.Feed(".")
        if (String_Contains(m, "250") && String_Contains(r, "250")
            && String_Contains(d, "354") && String_Contains(fin, "250")) {
            Console.WriteLine("[PASS] mail/rcpt/data dialogue")
        } else { Console.WriteLine("[FAIL] dialogue: " + m + "|" + r + "|" + d + "|" + fin) }

        // ── 8. message landed in the store, dot-unstuffed ──
        let uid: int = s.LastUid
        let body: string = store.Read("INBOX", uid)
        if (uid > 0 && String_Contains(body, "Hello body")
            && String_Contains(body, ".dotted line")
            && !String_Contains(body, "..dotted line")) {
            Console.WriteLine("[PASS] delivered + dot-unstuffed")
        } else { Console.WriteLine("[FAIL] delivered: uid=" + String_FromInt(uid) + " body=" + body) }

        // ── 9. AUTH LOGIN failure (wrong password) ───────
        let s2: SmtpSession = new SmtpSession(store, "mail.test")
        s2.AddPassword("alice", "s3cret")
        s2.SetTlsActive(true)
        let f1: string = s2.Feed("AUTH LOGIN")
        let f2: string = s2.Feed("YWxpY2U=")             // alice
        let f3: string = s2.Feed("d3Jvbmc=")             // base64("wrong")
        let notAuthed: bool = s2.Authed
        if (String_Contains(f3, "535") && !notAuthed) { Console.WriteLine("[PASS] auth login failure") }
        else { Console.WriteLine("[FAIL] auth login failure: " + f3) }

        // ── 10. QUIT ─────────────────────────────────────
        let q: string = s.Feed("QUIT")
        let isq: bool = s.IsQuit()
        if (String_Contains(q, "221") && isq) { Console.WriteLine("[PASS] quit") }
        else { Console.WriteLine("[FAIL] quit: " + q) }

        // ── 11. unknown command ──────────────────────────
        let s3: SmtpSession = new SmtpSession(store, "mail.test")
        let unk: string = s3.Feed("FROBNICATE x")
        if (String_Contains(unk, "500")) { Console.WriteLine("[PASS] unknown command") }
        else { Console.WriteLine("[FAIL] unknown command: " + unk) }

        // ── (sec) DNSBL listed / not-listed (Spamhaus test addrs) ──
        let bl: bool = Dnsbl.Listed("127.0.0.2", "zen.spamhaus.org")
        let nbl: bool = Dnsbl.Listed("127.0.0.1", "zen.spamhaus.org")
        if (bl && !nbl) { Console.WriteLine("[PASS] dnsbl") }
        else { Console.WriteLine("[FAIL] dnsbl (listed-test should be true, not-listed should be false)") }

        // ── 12. anti-relay: unauth, non-local recipient rejected ──
        let hr: SmtpSession = new SmtpSession(store, "mail.amalgame.me")
        hr.WithLocalDomain("amalgame.me")
        let hr0: string = hr.Feed("EHLO client")
        let hrm: string = hr.Feed("MAIL FROM:<someone@external.com>")     // inbound from world → ok
        let hrRelay: string = hr.Feed("RCPT TO:<victim@elsewhere.com>")   // non-local, unauth → denied
        let hrLocal: string = hr.Feed("RCPT TO:<alice@amalgame.me>")      // local → ok
        if (String_Contains(hrm, "250") && String_Contains(hrRelay, "550") && String_Contains(hrLocal, "250")) {
            Console.WriteLine("[PASS] anti-relay")
        } else { Console.WriteLine("[FAIL] anti-relay: m=" + hrm + " relay=" + hrRelay + " local=" + hrLocal) }

        // ── 13. anti-spoof: unauth MAIL FROM in local domain rejected ──
        let sp: SmtpSession = new SmtpSession(store, "mail.amalgame.me")
        sp.WithLocalDomain("amalgame.me")
        let sp0: string = sp.Feed("EHLO client")
        let spr: string = sp.Feed("MAIL FROM:<alice@amalgame.me>")
        if (String_Contains(spr, "550")) { Console.WriteLine("[PASS] anti-spoof own domain") }
        else { Console.WriteLine("[FAIL] anti-spoof: " + spr) }

        // ── 14. AUTH brute-force lockout ──────────────────
        let lk: SmtpSession = new SmtpSession(store, "mail.amalgame.me")
        lk.AddPassword("alice", "s3cret")
        lk.SetTlsActive(true)
        var fails: int = 0
        for i in 0..5 {
            let a: string = lk.Feed("AUTH LOGIN")
            let u: string = lk.Feed("YWxpY2U=")        // alice
            let p: string = lk.Feed("d3Jvbmc=")        // wrong
            if (String_Contains(p, "535")) { fails = fails + 1 }
        }
        let locked: string = lk.Feed("AUTH LOGIN")     // 6th → locked
        if (fails == 5 && String_Contains(locked, "454")) { Console.WriteLine("[PASS] auth lockout") }
        else { Console.WriteLine("[FAIL] auth lockout: fails=" + String_FromInt(fails) + " locked=" + locked) }

        // ── 15. SIZE cap ──────────────────────────────────
        let sz: SmtpSession = new SmtpSession(store, "mail.test")
        sz.WithMaxSize(40)
        let z0: string = sz.Feed("EHLO client")
        let zm: string = sz.Feed("MAIL FROM:<a@external.com>")
        let zr: string = sz.Feed("RCPT TO:<u@mail.test>")
        let zd: string = sz.Feed("DATA")
        let zb: string = sz.Feed("this line is definitely longer than forty bytes total here")
        let zf: string = sz.Feed(".")
        if (String_Contains(zf, "552")) { Console.WriteLine("[PASS] size cap") }
        else { Console.WriteLine("[FAIL] size cap: " + zf) }

        // ── 16. submission relay: authed sender, external recipient → relayed ──
        let rec: RelayRec = new RelayRec()
        let rl: SmtpSession = new SmtpSession(store, "mail.amalgame.me")
        rl.WithLocalDomain("amalgame.me")
        rl.AddPassword("alice", "s3cret")
        rl.SetTlsActive(true)
        rl.WithRelay(msg => {
            rec.Count = rec.Count + 1
            rec.LastFrom = msg.From
            rec.LastTo = msg.To
            return rec.Ok
        })
        let rla: string = rl.Feed("AUTH LOGIN")
        let rlu: string = rl.Feed("YWxpY2U=")            // alice
        let rlp: string = rl.Feed("czNjcmV0")            // s3cret
        let rle: string = rl.Feed("EHLO client")
        let rlm: string = rl.Feed("MAIL FROM:<alice@amalgame.me>")
        let rlr: string = rl.Feed("RCPT TO:<friend@gmail.com>")   // external, authed → accepted
        let rld: string = rl.Feed("DATA")
        let rlb: string = rl.Feed("Subject: hi")
        let rlb2: string = rl.Feed("")
        let rlb3: string = rl.Feed("hello friend")
        let rlf: string = rl.Feed(".")
        if (String_Contains(rlr, "250") && String_Contains(rlf, "relayed")
            && rec.Count == 1 && rec.LastTo == "friend@gmail.com" && rec.LastFrom == "alice@amalgame.me") {
            Console.WriteLine("[PASS] submission relay")
        } else { Console.WriteLine("[FAIL] submission relay: r=" + rlr + " fin=" + rlf + " count=" + String_FromInt(rec.Count) + " to=" + rec.LastTo) }

        // ── 17. authed external recipient but NO relay configured → 551 ──
        let nr: SmtpSession = new SmtpSession(store, "mail.amalgame.me")
        nr.WithLocalDomain("amalgame.me")
        nr.AddPassword("alice", "s3cret")
        nr.SetTlsActive(true)
        let nra: string = nr.Feed("AUTH LOGIN")
        let nru: string = nr.Feed("YWxpY2U=")
        let nrp: string = nr.Feed("czNjcmV0")
        let nre: string = nr.Feed("EHLO client")
        let nrm: string = nr.Feed("MAIL FROM:<alice@amalgame.me>")
        let nrr: string = nr.Feed("RCPT TO:<friend@gmail.com>")
        let nrd: string = nr.Feed("DATA")
        let nrb: string = nr.Feed("body")
        let nrf: string = nr.Feed(".")
        if (String_Contains(nrr, "250") && String_Contains(nrf, "551")) {
            Console.WriteLine("[PASS] no-relay external rejected")
        } else { Console.WriteLine("[FAIL] no-relay external: r=" + nrr + " fin=" + nrf) }
    }
}
